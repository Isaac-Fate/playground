# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Like system - 32+ char random string for IP hashing
LIKE_SYSTEM_SALT=your-32-char-random-salt-here

# Migrations: use explicit scripts to avoid wrong DB
#   pnpm db:migrate:dev   → .env.local
#   pnpm db:migrate:prod  → .env
